{
  "name": "afk-1",
  "version": "0.1.0",
  "description": "A basic TypeScript CLI template using Commander and Vitest",
  "type": "module",
  "bin": {
    "afk": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "cli": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@types/node": "^26.1.0",
    "init": "^0.1.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  }
}
